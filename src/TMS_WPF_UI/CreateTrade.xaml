<Window x:Class="TMS_WPF_UI.CreateTrade"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Trade"
        Height="720"
        Width="820"
        MinHeight="650"
        MinWidth="780"
        Background="#F5F7FA">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Create Trade"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#172033"
                       Margin="0,0,0,18"/>

            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Trade Type"/>
                    <ComboBox ItemsSource="{Binding TradeTypes}"
                              SelectedItem="{Binding Trade.TradeType, UpdateSourceTrigger=PropertyChanged}"
                              SelectionChanged="TradeType_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="Trade Reference"/>
                    <TextBox Text="{Binding Trade.TradeReference, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Side"/>
                    <ComboBox ItemsSource="{Binding Sides}"
                              SelectedItem="{Binding Trade.Side, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,12,12,0">
                    <TextBlock Text="Counterparty"/>
                    <TextBox Text="{Binding Trade.Counterparty, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,12,12,0">
                    <TextBlock Text="Bank Account"/>
                    <TextBox Text="{Binding Trade.CounterpartyBankAccount, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,12,0,0">
                    <TextBlock Text="Fees"/>
                    <TextBox Text="{Binding Trade.Fees, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>

            <GroupBox Grid.Row="2" Header="Amounts" Padding="12" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Currency 1"/>
                        <ComboBox ItemsSource="{Binding Currencies}"
                                  SelectedItem="{Binding Trade.Currency1, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Amount 1"/>
                        <TextBox Text="{Binding Trade.Amount1, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="FX Rate Used"/>
                        <TextBox Text="{Binding Trade.FxRateUsed, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,12,12,0">
                        <TextBlock Text="Currency 2"/>
                        <ComboBox ItemsSource="{Binding Currencies}"
                                  SelectedItem="{Binding Trade.Currency2, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,12,12,0">
                        <TextBlock Text="Amount 2"/>
                        <TextBox Text="{Binding Trade.Amount2, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,12,0,0">
                        <TextBlock Text="Rate Date"/>
                        <DatePicker SelectedDate="{Binding Trade.RateDate}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="3" Header="Dates" Padding="12" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Trade Date"/>
                        <DatePicker SelectedDate="{Binding Trade.TradeDate}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Settlement Date"/>
                        <DatePicker SelectedDate="{Binding Trade.SettlementDate}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="4"
                      Header="Forward / Swap Details"
                      Padding="12"
                      Margin="0,0,0,16"
                      Visibility="{Binding IsForwardOrSwap, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Near Leg Date"/>
                        <DatePicker SelectedDate="{Binding Trade.NearLegDate}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Near Leg Rate"/>
                        <TextBox Text="{Binding Trade.NearLegRate, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Near Leg Amount 1"/>
                        <TextBox Text="{Binding Trade.NearLegAmount1, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,12,12,0">
                        <TextBlock Text="Near Leg Amount 2"/>
                        <TextBox Text="{Binding Trade.NearLegAmount2, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,12,12,0"
                                Visibility="{Binding IsSwap, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Far Leg Date"/>
                        <DatePicker SelectedDate="{Binding Trade.FarLegDate}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,12,0,0"
                                Visibility="{Binding IsSwap, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Far Leg Rate"/>
                        <TextBox Text="{Binding Trade.FarLegRate, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,12,12,0"
                                Visibility="{Binding IsSwap, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Far Leg Amount 1"/>
                        <TextBox Text="{Binding Trade.FarLegAmount1, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,12,12,0"
                                Visibility="{Binding IsSwap, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Far Leg Amount 2"/>
                        <TextBox Text="{Binding Trade.FarLegAmount2, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,12,0,0"
                                Visibility="{Binding IsSwap, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Swap Points"/>
                        <TextBox Text="{Binding Trade.SwapPoints, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Comments"/>
                    <TextBox Height="70"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Text="{Binding Trade.Comments, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="{Binding Message}"
                               Foreground="#B00020"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="16,0,0,0">
                    <Button Content="Reset" Width="88" Height="32" Margin="0,0,8,0" Command="{Binding ResetCommand}"/>
                    <Button Content="Save" Width="88" Height="32" Margin="0,0,8,0" Command="{Binding SaveCommand}"/>
                    <Button Content="Cancel" Width="88" Height="32" Command="{Binding CancelCommand}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
