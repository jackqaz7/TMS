<Window x:Class="TMS_WPF_UI.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TMS_WPF_UI"
        mc:Ignorable="d"
        Title="Login" Height="450" Width="800" Background="#FAF9F6">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="20" Background="#FAF9F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Username -->
        <TextBlock Text="Username:" Grid.Row="0" Margin="0,0,0,5"/>
        <TextBox Grid.Row="0" Margin="100,0,0,5" Width="200"
             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Password -->
        <TextBlock Text="Password:" Grid.Row="1" Margin="0,0,0,5"/>
        <PasswordBox Grid.Row="1" Margin="100,0,0,5" Width="200"
                 PasswordChanged="PasswordBox_PasswordChanged"/>

        <!-- Login Button -->
        <Button Content="Login" Grid.Row="2" Width="80" Margin="0,10,0,0"
            HorizontalAlignment="Left"
            Command="{Binding LoginCommand}"/>

        <!-- Message -->
        <TextBlock Grid.Row="3" Foreground="Red" Margin="0,10,0,0"
               Text="{Binding Message}"/>
        
        <!-- Progress bar -->
        <ProgressBar Grid.Row="2"
             Margin="100,10,0,0"
             Width="120"
             Height="16"
             IsIndeterminate="True"
             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>

</Window>

