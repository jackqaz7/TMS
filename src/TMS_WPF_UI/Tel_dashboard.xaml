<Window x:Class="TMS_WPF_UI.Tel_dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
        Title="Treasury Management Dashboard - Telerik"
        Height="560"
        Width="980"
        MinHeight="520"
        MinWidth="900"
        Loaded="Window_Loaded">

    <Grid Background="#F5F7FA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FFB3E5FC" Padding="16">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top"
                           Text="TMS"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Margin="0,0,0,24"/>

                <telerik:RadTreeView Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White">
                    <telerik:RadTreeViewItem Header="Treasury" IsExpanded="True">
                        <telerik:RadTreeViewItem Header="Positions" IsSelected="True"/>
                        <telerik:RadTreeViewItem Header="Trades"/>
                        <telerik:RadTreeViewItem Header="Payments"/>
                    </telerik:RadTreeViewItem>
                    <telerik:RadTreeViewItem Header="Manufacturing">
                        <telerik:RadTreeViewItem Header="Orders"/>
                        <telerik:RadTreeViewItem Header="Inventory"/>
                    </telerik:RadTreeViewItem>
                    <telerik:RadTreeViewItem Header="Audit">
                        <telerik:RadTreeViewItem Header="Events"/>
                        <telerik:RadTreeViewItem Header="Logs"/>
                    </telerik:RadTreeViewItem>
                </telerik:RadTreeView>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,18">
                <telerik:RadButton DockPanel.Dock="Right"
                                   Content="Logout"
                                   Width="92"
                                   Height="32"
                                   Click="Logout_Click"/>

                <StackPanel>
                    <TextBlock Text="Treasury Positions"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="#172033"/>
                    <TextBlock Text="Telerik replica of the native WPF dashboard"
                               Foreground="#5D6678"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>

            <DockPanel Grid.Row="1" Margin="0,0,0,12">
                <telerik:RadButton DockPanel.Dock="Left"
                                   Content="Refresh"
                                   Width="96"
                                   Height="32"
                                   Command="{Binding RefreshPositionsCommand}"/>

                <telerik:RadButton DockPanel.Dock="Left"
                                   Content="New Trade"
                                   Width="100"
                                   Height="32"
                                   Margin="8,0,0,0"
                                   Click="NewTrade_Click"/>

                <TextBlock Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="#5D6678"
                           Margin="12,0,0,0"/>
            </DockPanel>

            <telerik:RadBusyIndicator Grid.Row="2"
                                      IsBusy="{Binding IsLoading}"
                                      BusyContent="Loading positions...">
                <telerik:RadGridView ItemsSource="{Binding Positions}"
                                     AutoGenerateColumns="False"
                                     IsReadOnly="True"
                                     ShowGroupPanel="True"
                                     CanUserFreezeColumns="False"
                                     RowIndicatorVisibility="Collapsed"
                                     SelectionMode="Single">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewDataColumn Header="Currency"
                                                    DataMemberBinding="{Binding Currency}"
                                                    Width="110"/>
                        <telerik:GridViewDataColumn Header="Buy Notional"
                                                    DataMemberBinding="{Binding BuyNotional, StringFormat=N2}"
                                                    Width="150"/>
                        <telerik:GridViewDataColumn Header="Sell Notional"
                                                    DataMemberBinding="{Binding SellNotional, StringFormat=N2}"
                                                    Width="150"/>
                        <telerik:GridViewDataColumn Header="Net Notional"
                                                    DataMemberBinding="{Binding NetNotional, StringFormat=N2}"
                                                    Width="150"/>
                        <telerik:GridViewDataColumn Header="Avg Rate"
                                                    DataMemberBinding="{Binding WeightedAverageRate, StringFormat=N6}"
                                                    Width="130"/>
                        <telerik:GridViewDataColumn Header="Trades"
                                                    DataMemberBinding="{Binding TradeCount}"
                                                    Width="90"/>
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
            </telerik:RadBusyIndicator>

            <TextBlock Grid.Row="3"
                       Text="Same data path as WPF_Dashboard: SQL Server -> EF Core -> ASP.NET Core REST -> JWT-authenticated WPF client"
                       Foreground="#7A8496"
                       Margin="0,12,0,0"/>
        </Grid>
    </Grid>
</Window>
