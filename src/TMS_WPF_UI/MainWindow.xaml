<Window x:Class="TMS_WPF_UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TMS_WPF_UI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid>
        <!-- Define two columns: left for menu, right for dashboard -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <!-- Menu tree -->
            <ColumnDefinition Width="*"/>
            <!-- Dashboard -->
        </Grid.ColumnDefinitions>

        <!-- Left Menu Tree -->
        <TreeView Grid.Column="0" Margin="10,10,80,10">
            <TreeViewItem Header="Treasury">
                <TreeViewItem Header="Payments"/>
                <TreeViewItem Header="Reports"/>
            </TreeViewItem>
            <TreeViewItem Header="Manufacturing">
                <TreeViewItem Header="Orders"/>
                <TreeViewItem Header="Inventory"/>
            </TreeViewItem>
            <TreeViewItem Header="Audit">
                <TreeViewItem Header="Events"/>
                <TreeViewItem Header="Logs"/>
            </TreeViewItem>
        </TreeView>

        <!-- Dashboard Area -->
        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="11*"/>
                <RowDefinition Height="20*"/>
            </Grid.RowDefinitions>

            <!-- Dashboard Header -->
            <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold" Margin="-83,0,0,10"/>

            <!-- Dashboard Content -->
            <StackPanel Grid.Row="1" Margin="-83,0,0,0" Grid.RowSpan="2">
                <TextBlock Text="Welcome, Arjun!" FontSize="18" Margin="0,0,0,20"/>
                <Button Content="View Reports" Width="150" Margin="0,0,0,10"/>
                <Button Content="Manage Orders" Width="150" Margin="0,0,0,10"/>
                <Button Content="Audit Logs" Width="150"/>
            </StackPanel>
        </Grid>
        <Button x:Name="Logout" Content="Logout" HorizontalAlignment="Left" Margin="475,368,0,0" VerticalAlignment="Top" Grid.Column="1" Click="Logout_Click"/>
    </Grid>
</Window>
